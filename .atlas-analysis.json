  "keyFeatures": [
    "Multi-tenant SaaS architecture with role-based access control",
    "Comprehensive inventory management with stock tracking and movements",
    "Point of Sale (POS) system with barcode scanning and receipt printing",
    "E-commerce storefront with payment gateway integration",
    "Full payroll system with tax calculation and NIBSS export",
    "Supplier management with catalog and purchase orders",
    "Multi-shop support with individual currency and VAT settings",
    "Service booking alongside product sales",
    "Customer credit management and loyalty tracking",
    "Real-time notifications and approval workflows"
  ],
  "publicApiSurface": [
    "ProductService - Product and variant management",
    "OrderService - Order processing and fulfillment",
    "POSService - Point of sale operations",
    "StockMovementService - Inventory tracking and adjustments",
    "PayrollService - Employee payroll processing",
    "CustomerService - Customer and credit management",
    "SupplierService - Supplier catalog and connections",
    "CheckoutService - E-commerce checkout flow",
    "PaymentGateway - Payment processing integration",
    "NotificationService - Multi-channel notifications",
    "ApprovalService - Workflow approvals",
    "ReportService - Analytics and reporting"
  ]
